# ============================================
# Backend env — copy to backend/.env
# ============================================

# --- Runtime ---
NODE_ENV=development
PORT=3000

# CORS. Comma-separated browser origins. credentials:true is on, so the origin
# must match exactly or browsers block credentialed requests.
ALLOWED_ORIGINS=http://localhost:5173

# Upload safety limit (MB). Production streams uploads to object storage via API.
MAX_UPLOAD_MB=250

# --- Database (Supabase Postgres) ---
# Project Settings > Database > Connection string.
# Transaction-mode pooler (port 6543) is recommended; client.ts disables
# prepared statements so it works with the pooler out of the box.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Object storage (Supabase Storage via S3-compatible API) ---
# Required in staging/production: worker.ts throws without STORAGE_PROVIDER=s3.
# Get S3 credentials: Project Settings > Storage > S3 Connection.
# Bucket name is whatever you created under Storage in the Supabase dashboard.
STORAGE_PROVIDER=s3
S3_ENDPOINT=https://[ref].supabase.co/storage/v1/s3
S3_REGION=us-east-1
S3_BUCKET=alto-uploads
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_FORCE_PATH_STYLE=false
S3_SIGNED_URL_TTL_SEC=900

# Browser direct upload to signed URL (true) vs API-streamed upload (false).
# true requires R2/Supabase CORS configured for PUT from the frontend origin.
# false = the API proxies the stream (default, no storage CORS needed).
BROWSER_DIRECT_UPLOAD=false

# --- Worker ---
WORKER_POLL_MS=5000

# --- Login rate limit ---
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SEC=900

# --- Transcription (Deepgram, active provider) ---
# Only Deepgram is wired into the runtime transcription path.
DEEPGRAM_API_KEY=your-deepgram-key
DEEPGRAM_MODEL=nova-3-general

# --- Summary generation (GLM via ZhipuAI / z.ai OpenAI-compatible endpoint) ---
# Base URL for OpenAI SDK. Official Zhipu endpoint is https://open.bigmodel.cn/api/paas/v4;
# z.ai mirror is https://api.z.ai/api/paas/v4. Keep whichever issued your key.
GLM_API_KEY=your-glm-key
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-5.2

# --- Initial admin seed ---
# Seed refuses weak passwords (e.g. "123", <8 chars) in staging/production.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-min-8-chars

# ============================================
# Frontend env — copy VITE_* vars to frontend/.env
# Only VITE_ prefixed vars are exposed to the browser bundle.
# ============================================

VITE_API_URL=http://localhost:3000
VITE_MAX_UPLOAD_MB=250
