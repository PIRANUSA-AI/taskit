# ============================================
# Backend env — copy to backend/.env
# ============================================

# --- Runtime ---
NODE_ENV=development
PORT=3000

# CORS. In dev, the frontend runs on :5173. In production via nginx,
# everything is same-origin — leave ALLOWED_ORIGINS empty or remove it.
ALLOWED_ORIGINS=http://localhost:5173

# Upload safety limit (MB). Production streams uploads to object storage via API.
MAX_UPLOAD_MB=250

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Object storage (Cloudflare R2 via S3-compatible API) ---
# Worker throws without STORAGE_PROVIDER=s3.
# Get R2 credentials: Cloudflare Dashboard > R2 > Manage R2 API Tokens.
STORAGE_PROVIDER=s3
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=pinote
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SEC=900

# Browser direct upload
BROWSER_DIRECT_UPLOAD=false

# --- Worker ---
WORKER_POLL_MS=5000

# --- Login rate limit ---
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SEC=900

# --- Transcription (Deepgram) ---
DEEPGRAM_API_KEY=your-deepgram-key
DEEPGRAM_MODEL=nova-3-general
# Comma-separated words to boost during recognition (names, brands, terms)
DEEPGRAM_KEYWORDS=
# Max keyterm params per request (env keywords + DB user names, deduped). Avoids URL bloat.
DEEPGRAM_MAX_KEYTERMS=50
# Retry attempts on transient Deepgram errors (429 / 5xx / network)
DEEPGRAM_MAX_RETRIES=3
# Meetings shorter than this (sec) go to Deepgram in ONE call (keeps speaker
# diarization consistent). >= this are ffmpeg-split into CHUNK_DURATION_SEC chunks.
# Default 7200 (2h). Lower only if you hit Deepgram payload/timeout limits.
DIRECT_THRESHOLD_SEC=7200
# Chunk length (sec) when splitting is needed. Default 1800 (30 min).
CHUNK_DURATION_SEC=1800

# --- Summary generation (GLM via ZhipuAI) ---
GLM_API_KEY=your-glm-key
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-5.2

# --- Initial admin seed ---
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-min-8-chars

# --- Public signup ---
ALLOW_PUBLIC_SIGNUP=1
SIGNUP_CREDIT_SECONDS=600

# --- Transcript polish ---
TRANSCRIPT_POLISH=1

# --- Firebase (Google Auth) ---
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Whitelist email tertentu (selain domain @piranusa.com / @contrivent.com)
# Contoh: WHITELIST_EMAILS=yoelandreasmanoppo@gmail.com,email2@gmail.com
WHITELIST_EMAILS=

# --- Email (Resend — gratis 100 email/hari) ---
# Daftar di resend.com, verify domain, dapet API key
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Pinote <noreply@contrivent.com>

# ============================================
# Frontend env — prefix with VITE_ for build
# ============================================
# Dev:  VITE_API_URL=http://localhost:3000
# Prod: VITE_API_URL=/api
VITE_API_URL=http://localhost:3000
VITE_MAX_UPLOAD_MB=250
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
