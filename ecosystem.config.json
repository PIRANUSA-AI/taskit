{
  "apps": [
    {
      "name": "pinote-api",
      "script": "dist/index.js",
      "cwd": "/var/www/pinote/backend",
      "env": {
        "NODE_ENV": "production",
        "PORT": "3000"
      },
      "instances": 1,
      "exec_mode": "fork",
      "max_memory_restart": "512M",
      "error_file": "/var/log/pinote/api-error.log",
      "out_file": "/var/log/pinote/api-out.log",
      "merge_logs": true,
      "time": true
    },
    {
      "name": "pinote-worker",
      "script": "dist/worker.js",
      "cwd": "/var/www/pinote/backend",
      "env": {
        "NODE_ENV": "production",
        "PORT": "3001",
        "STORAGE_PROVIDER": "s3"
      },
      "instances": 1,
      "exec_mode": "fork",
      "max_memory_restart": "512M",
      "error_file": "/var/log/pinote/worker-error.log",
      "out_file": "/var/log/pinote/worker-out.log",
      "merge_logs": true,
      "time": true
    }
  ]
}
